rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.uid is string 
          && data.uid.size() <= 128
          && (data.email == null || (data.email is string && data.email.size() <= 256))
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 256))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048))
          && (data.createdAt == null || data.createdAt is string);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }
  }
}
